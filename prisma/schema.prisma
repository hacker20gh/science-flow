generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== 用户 =====

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  password  String?  // bcrypt 哈希后的密码
  llmConfig Json?    // { baseUrl, models: { extraction, chat, analysis } }
  projects  Project[]
  chatMessages    ChatMessage[]
  conversations   Conversation[]
  courseProgress  CourseProgress[]
  createdAt DateTime @default(now())
}

// ===== 用户设置（通用 KV 存储） =====

model UserSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ===== 项目 =====

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  deletedAt   DateTime? // 软删除：null=正常，非null=在回收站

  papers       Paper[]
  experiments  Experiment[]
  hypotheses   Hypothesis[]
  timeline     TimelineEvent[]
  manuscripts  Manuscript[]
  chatMessages  ChatMessage[]
  conversations Conversation[]
  searchHistory SearchHistory[]
  matrix        MechanismMatrix?
  todos         TodoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, deletedAt])
}

// ===== 文献 =====

model Paper {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  doi          String?
  pmid         String?
  title        String
  authors      String[]
  journal      String?
  year         Int?
  impactFactor Float?
  abstract     String?
  fullText     String?

  extractions Extraction[]

  source String? // pubmed, semantic_scholar, user_upload
  oaUrl  String? // Open Access URL

  createdAt DateTime @default(now())

  @@unique([projectId, doi])
  @@index([projectId])
  @@index([pmid])
}

// ===== 文献提取结果 =====

model Extraction {
  id      String @id @default(cuid())
  paperId String
  paper   Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)

  drugName     String?  // 药物/干预名称
  drugConc     String?  // 药物浓度
  duration     String?  // 处理时间，如 24h
  coTreatment  String?  // 联合处理
  cellLine     String?  // 细胞系
  species      String?  // 物种（human, mouse 等）
  passage      String?  // 传代范围
  pathway      String?  // 信号通路（第一个，向后兼容）
  pathwayDir   String?  // up, down, no_change
  phenotype    String?  // 表型（第一个，向后兼容）
  phenotypeDir String?  // up, down, no_change
  method       String?  // 统计方法（ANOVA, t-test 等）
  expMethod    String?  // 实验方法（Western blot, qPCR 等）
  conclusion   String?  // 关键结论
  rawText      String?  // 原文片段（用于溯源）

  // 完整的通路/表型效应（多值）
  pathwayEffects  Json?   // [{ pathway, direction, significance, method }]
  phenotypeEffects Json?  // [{ phenotype, direction, fold_change }]

  controls   Json?     // 对照组列表 ["Vehicle", "TNF-α positive"]
  sampleSize Int?      // 样本量（生物学重复数）
  confidence Float?    // LLM 提取置信度 0-1
  verified   Boolean   @default(false)

  createdAt DateTime @default(now())

  @@index([paperId])
  @@index([verified])
}

// ===== 假设 =====

model Hypothesis {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  statement  String   // 假设陈述
  status     String   // pending, testing, supported, refused, revised
  evidence   Json?    // 支持/反对证据
  basedOn    String[] // 基于哪些文献/实验

  experiments Experiment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== 实验 =====

model Experiment {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  hypothesisId String?
  hypothesis   Hypothesis? @relation(fields: [hypothesisId], references: [id])

  name     String // 实验名称
  type     String // western_blot, flow_cytometry, qpcr, etc.
  status   String // designed, running, completed, failed
  protocol Json   // 结构化 Protocol
  variables Json  // 自变量、因变量、对照组

  result      Json?     // 分析结果
  rawData     ExperimentData[]

  troubleshoot Json? // 失败原因和诊断

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExperimentData {
  id           String     @id @default(cuid())
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id])

  fileType   String // excel, csv, image
  fileName   String
  fileUrl    String // Supabase Storage URL
  parsedData Json?  // 解析后的结构化数据
  analysis   Json?  // 统计分析结果

  createdAt DateTime @default(now())
}

// ===== 时间线事件 =====

model TimelineEvent {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  type       String // literature, hypothesis, experiment_design,
                    // experiment_fail, experiment_success,
                    // pivot, manuscript, data_upload
  title      String
  content    Json   // 事件详情（结构化）
  metadata   Json?  // 附加信息

  sortOrder  Int    @default(0)
  weekNumber Int?

  createdAt DateTime @default(now())
}

// ===== 论文草稿 =====

model Manuscript {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  journal  String?
  language String @default("en")

  abstract    String?
  introduction String?
  methods     String?
  results     String?
  discussion  String?
  references  Json?

  reviewSimulation Json? // 审稿人模拟

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== AI 对话消息 =====

model ChatMessage {
  id             String       @id @default(cuid())
  projectId      String
  userId         String
  conversationId String?
  role           String       // "user" | "assistant" | "system"
  content        String
  metadata       Json?        // token usage, model used, tool calls, etc.
  createdAt      DateTime     @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([userId])
  @@index([conversationId])
}

// ===== 对话管理 =====

model Conversation {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  title     String   @default("新对话")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]
  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, userId])
  @@index([userId])
}

// ===== 搜索历史 =====

model SearchHistory {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  query          String   // 用户输入的原始搜索词
  optimizedQuery String?  // LLM 优化后的搜索词
  sources        String[] // 使用的学术源
  maxResults     Int      // 请求的最大结果数
  resultCount    Int      // 实际返回的结果数
  searchParams   Json?    // 完整搜索参数（用于精确重放）
  resultSnapshot Json?    // 搜索结果快照（用于秒级回放）
  createdAt      DateTime @default(now())

  @@index([projectId, createdAt])
}

// ===== 机制矩阵（持久化） =====

model MechanismMatrix {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  data      Json     // MatrixData 的 JSON 序列化（rows, columns, conflicts, gaps）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId])
  @@index([projectId])
}

// ===== 待办事项 =====

model TodoItem {
  id          String    @id @default(cuid())
  projectId   String
  type        String    // conflict | gap | suggestion | experiment_check
  title       String
  detail      String?
  status      String    @default("pending") // pending | completed
  metadata    Json?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

// ===== 课程进度 =====

model CourseProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  lessonId    String
  status      String    @default("not_started") // not_started | in_progress | completed
  startedAt   DateTime?
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId, courseId])
}

// ===== Token 用量追踪 =====

model TokenUsage {
  id           String   @id @default(cuid())
  feature      String   // extraction, chat, design, troubleshoot, analysis, manuscript, review, preprocess
  model        String
  inputTokens  Int
  outputTokens Int
  cachedTokens Int      @default(0)
  durationMs   Int      @default(0)
  isRetry      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([feature, createdAt])
  @@index([createdAt])
}
